# Copy to .env and fill in. The deploy scripts read this file.

# REQUIRED: shared password everyone uses to log in to the web UI.
FRE_WEB_PASSWORD=change-me

# Optional for API-backed LLM-assisted theme drafting. Local Claude Code mode
# (`FRE_MODEL=claude-cli`) uses `claude login` instead of an API key.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# Model selection. Default uses the local Claude Code subscription/login.
FRE_MODEL=claude-cli
FRE_MODEL_NAME=

# Codex subscription example (keyless: uses the local `codex login` from
# ~/.codex, runs `codex exec` read-only/ephemeral per completion):
# FRE_MODEL=codex
# FRE_MODEL_NAME=            # optional specific codex model id
# CODEX_CLI_CMD=codex exec   # optional binary/subcommand override

# Optional tuning.
# FRE_MAX_TOKENS=16000        # per-call output token cap
# FRE_MAX_CONCURRENCY=2       # simultaneous drafting jobs (keep low on small boxes)
# FRE_WEB_SECRET=             # cookie signing secret (defaults to derive from password)
# FRE_WEB_DATA_DIR=           # where sessions/runs are stored (default: ./web_data)
# FRE_HOST=0.0.0.0
# PORT=8000

# DeepSeek example:
# FRE_MODEL=deepseek
# FRE_MODEL_NAME=deepseek-v4-pro
# DEEPSEEK_API_KEY=
# DEEPSEEK_THINKING=disabled

# Anthropic API example:
# FRE_MODEL=claude
# FRE_MODEL_NAME=claude-opus-4-8
# ANTHROPIC_API_KEY=
