# Copy to .env and fill in. The deploy scripts read this file.

# REQUIRED: shared password everyone uses to log in to the web UI.
FRE_WEB_PASSWORD=change-me

# REQUIRED for LLM-assisted theme drafting (guided analysis / critique / refine).
# One server-side key; all users share it. Read-only endpoints (run/audit/diff)
# do not need it. Fill the key that matches FRE_MODEL below.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# Model selection.
FRE_MODEL=claude
FRE_MODEL_NAME=claude-opus-4-8

# Optional tuning.
# FRE_MAX_TOKENS=16000        # per-call output token cap
# FRE_MAX_CONCURRENCY=2       # simultaneous drafting jobs (keep low on small boxes)
# FRE_WEB_SECRET=             # cookie signing secret (defaults to derive from password)
# FRE_WEB_DATA_DIR=           # where sessions/runs are stored (default: ./web_data)
# FRE_HOST=0.0.0.0
# PORT=8000

# DeepSeek example:
# FRE_MODEL=deepseek
# FRE_MODEL_NAME=deepseek-v4-pro
# DEEPSEEK_API_KEY=
# DEEPSEEK_THINKING=disabled
